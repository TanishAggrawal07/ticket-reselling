<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Dark header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary_dark"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="52dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/list_your_ticket"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sell_ticket_subtitle"
                android:textColor="@color/text_on_dark"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Event Image Upload (OPTIONAL) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Event Image"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_optional_badge"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:text="Optional"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Image preview -->
            <FrameLayout
                android:id="@+id/frame_event_image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_event_image_preview"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="Event image preview" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="#99000000"
                    android:gravity="end"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_change_event_image"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:text="Change"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        app:cornerRadius="8dp"
                        app:strokeColor="@color/white"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_remove_event_image"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:backgroundTint="#CCDC2626"
                        android:text="Remove"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        app:cornerRadius="8dp"
                        app:elevation="0dp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Image picker -->
            <LinearLayout
                android:id="@+id/layout_event_image_picker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_upload_area"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_image"
                    android:layout_marginBottom="8dp"
                    app:tint="@color/accent_blue" />

                <TextView
                    android:id="@+id/tv_event_image_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to upload event image"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="JPG, PNG accepted"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- ── Ticket File Upload (REQUIRED) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ticket File"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_required_badge"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:text="Required"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Ticket upload error -->
            <TextView
                android:id="@+id/tv_ticket_upload_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:drawableStart="@drawable/ic_info"
                android:drawablePadding="6dp"
                android:drawableTint="@color/error_red"
                android:gravity="center_vertical"
                android:text="Please upload your ticket (PDF or image)"
                android:textColor="@color/error_red"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Ticket file preview -->
            <LinearLayout
                android:id="@+id/frame_ticket_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_upload_area"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_attach_file"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/accent_blue" />

                <TextView
                    android:id="@+id/tv_ticket_file_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="middle"
                    android:maxLines="1"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_change_ticket_file"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginEnd="6dp"
                    android:text="Change"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/accent_blue"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_remove_ticket_file"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:backgroundTint="@color/error_red_light"
                    android:text="Remove"
                    android:textAllCaps="false"
                    android:textColor="@color/error_red"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:elevation="0dp" />
            </LinearLayout>

            <!-- Ticket file picker -->
            <LinearLayout
                android:id="@+id/layout_ticket_file_picker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_upload_area"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_attach_file"
                    android:layout_marginBottom="8dp"
                    app:tint="@color/accent_blue" />

                <TextView
                    android:id="@+id/tv_ticket_file_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload Ticket (PDF or Screenshot)"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="PDF or image accepted"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- ── Form Card ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Event Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/event_name"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/et_event_name"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="18dp"
                        android:background="@drawable/bg_input_field_selector"
                        android:hint="@string/hint_event_name"
                        android:inputType="textCapWords"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="15sp" />

                    <!-- Date -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/date"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/et_date"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="18dp"
                        android:background="@drawable/bg_input_field_selector"
                        android:drawableEnd="@drawable/ic_calendar"
                        android:drawableTint="@color/text_hint"
                        android:focusable="false"
                        android:hint="@string/hint_date"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="15sp" />

                    <!-- Pricing -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pricing"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/original_price_short"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:layout_marginBottom="6dp" />

                            <EditText
                                android:id="@+id/et_original_price"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:background="@drawable/bg_input_field_selector"
                                android:hint="₹0"
                                android:inputType="number"
                                android:paddingHorizontal="16dp"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_hint"
                                android:textSize="15sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/selling_price_short"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:layout_marginBottom="6dp" />

                            <EditText
                                android:id="@+id/et_selling_price"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:background="@drawable/bg_input_field_selector"
                                android:hint="₹0"
                                android:inputType="number"
                                android:paddingHorizontal="16dp"
                                android:textColor="@color/accent_blue"
                                android:textColorHint="@color/text_hint"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Recovery message -->
                    <TextView
                        android:id="@+id/tv_recovery_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pricing_badge"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="@string/enter_selling_price"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tips card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/accent_blue_light"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_info"
                        android:layout_marginEnd="12dp"
                        app:tint="@color/accent_blue" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pricing_tips"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="3dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pricing_tips_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:lineSpacingMultiplier="1.4" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Submit button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:backgroundTint="@color/accent_blue"
                android:text="@string/list_ticket"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="14dp"
                app:elevation="0dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="40dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
