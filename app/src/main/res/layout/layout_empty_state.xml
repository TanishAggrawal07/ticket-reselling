<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/spacing_32"
    android:paddingVertical="@dimen/spacing_48">

    <!-- Icon -->
    <ImageView
        android:id="@+id/iv_empty_icon"
        android:layout_width="@dimen/icon_xl"
        android:layout_height="@dimen/icon_xl"
        android:layout_marginBottom="@dimen/spacing_20"
        android:src="@drawable/ic_ticket"
        android:importantForAccessibility="no"
        app:tint="@color/text_hint" />

    <!-- Title -->
    <TextView
        android:id="@+id/tv_empty_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_18"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/spacing_8" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tv_empty_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_14"
        android:lineSpacingMultiplier="1.5" />

</LinearLayout>