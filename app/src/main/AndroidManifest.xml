<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet access — required for API backend communication -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Storage permission for picking images/files (API < 33) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Media permissions for API 33+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <application
        android:name=".ReTixApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Retix"
        tools:targetApi="31">

        <!-- Onboarding Activity -->
        <activity
            android:name=".OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.Retix" />

        <!-- Login Activity -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.Retix"
            android:windowSoftInputMode="adjustResize" />

        <!-- Signup Activity -->
        <activity
            android:name=".SignupActivity"
            android:exported="false"
            android:theme="@style/Theme.Retix"
            android:windowSoftInputMode="adjustResize" />

        <!-- Home Activity (legacy) -->
        <activity
            android:name=".HomeActivity"
            android:exported="false"
            android:theme="@style/Theme.Retix" />

        <!-- Ticket Detail Activity -->
        <activity
            android:name=".TicketDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Retix"
            android:parentActivityName=".MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <!-- Sell Ticket Activity -->
        <activity
            android:name=".SellTicketActivity"
            android:exported="false"
            android:theme="@style/Theme.Retix"
            android:parentActivityName=".MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <!-- Seller Profile Activity -->
        <activity
            android:name=".SellerProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Retix"
            android:parentActivityName=".TicketDetailActivity" />

        <!-- Settings Activity -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Retix"
            android:parentActivityName=".MainActivity" />

        <!-- Edit Profile Activity -->
        <activity
            android:name=".EditProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Retix"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".SettingsActivity" />

        <!-- MainActivity with Bottom Navigation - App Entry Point -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Retix">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Chat Activity -->
        <activity
            android:name=".ChatActivity"
            android:exported="false"
            android:theme="@style/Theme.Retix"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".TicketDetailActivity" />

    </application>

</manifest>
